    private function parseKitchenDrawTxt($file): array
    {
        $rows = [];
        $lineNumber = 0;
        $handle = fopen($file->getRealPath(), 'r');

        if (!$handle) {
            throw \Illuminate\Validation\ValidationException::withMessages([
                'txt_file' => 'No se pudo leer el archivo TXT de despiece.',
            ]);
        }

        while (($data = fgetcsv($handle, 0, ',')) !== false) {
            $lineNumber++;

            if (count($data) < 10) {
                continue;
            }

            $materialRaw = trim($data[7], '" ');
            $materialInfo = $this->splitMaterialAndColor($materialRaw);

            $row = [
                'line_number' => $lineNumber,
                'type_code' => (int) $data[0],
                'type_name' => $this->partTypeName((int) $data[0]),
                'part' => trim($data[1], '" '),
                'quantity' => (float) $data[2],
                'length' => (float) $data[3],
                'width' => (float) $data[4],
                'thickness' => (float) $data[5],
                'material_code' => trim($data[6], '" '),
                'material' => $materialInfo['material'],
                'color_code' => $materialInfo['color_code'],
                'color_description' => $materialInfo['color_description'],
                'module_number' => (int) $data[8],
                'module_reference' => trim($data[9], '" '),
            ];

            $materialPrice = \App\Models\MaterialPrice::query()
                ->where('material_code', $row['material_code'])
                ->where('is_active', true)
                ->first();

            $unitType = $materialPrice->unit_type ?? 'm2';
            $unitCost = (float) ($materialPrice->unit_cost ?? 0);
            $wastePercent = (float) ($materialPrice->waste_percent ?? 0);
            $quantity = (float) ($row['quantity'] ?? 0);
            $lengthMm = (float) ($row['length'] ?? 0);
            $widthMm = (float) ($row['width'] ?? 0);

            $consumption = 0;
            $areaM2 = 0;
            $linearM = 0;

            if ($unitType === 'm2') {
                $areaM2 = ($lengthMm / 1000) * ($widthMm / 1000) * $quantity;
                $consumption = $areaM2;
            } elseif ($unitType === 'ml') {
                $linearM = ($lengthMm / 1000) * $quantity;
                $consumption = $linearM;
            } else {
                $consumption = $quantity;
            }

            $baseCost = $consumption * $unitCost;
            $wasteCost = $baseCost * ($wastePercent / 100);
            $totalCost = $baseCost + $wasteCost;

            $row['unit_type'] = $unitType;
            $row['consumption'] = round($consumption, 4);
            $row['area_m2'] = round($areaM2, 4);
            $row['linear_m'] = round($linearM, 4);
            $row['unit_cost'] = round($unitCost, 4);
            $row['base_cost'] = round($baseCost, 4);
            $row['waste_percent'] = round($wastePercent, 2);
            $row['waste_cost'] = round($wasteCost, 4);
            $row['total_cost'] = round($totalCost, 4);

            $rows[] = $row;
        }

        fclose($handle);

        return $rows;
    }

    private function splitMaterialAndColor(string $materialRaw): array
    {
        $materialRaw = trim($materialRaw);

        if (str_contains($materialRaw, '_')) {
            [$material, $colorRaw] = explode('_', $materialRaw, 2);

            $colorRaw = trim($colorRaw);

            if (str_contains($colorRaw, ' ')) {
                [$colorCode, $colorDescription] = explode(' ', $colorRaw, 2);
            } else {
                $colorCode = $colorRaw;
                $colorDescription = '';
            }

            return [
                'material' => trim($material),
                'color_code' => trim($colorCode),
                'color_description' => trim($colorDescription),
            ];
        }

        return [
            'material' => $materialRaw,
            'color_code' => '',
            'color_description' => '',
        ];
    }

    private function expandModulesFromDespiece(array $modules, array $despiece): array
    {
        $expanded = [];
        $usedNumbers = [];

        $despieceByReference = collect($despiece)
            ->filter(function ($row) {
                return isset($row['module_number']) && (int) $row['module_number'] > 0;
            })
            ->groupBy(function ($row) {
                return trim($row['module_reference'] ?? '');
            })
            ->map(function ($rows) {
                return $rows
                    ->pluck('module_number')
                    ->map(fn($number) => (int) $number)
                    ->unique()
                    ->sort()
                    ->values()
                    ->all();
            });

        foreach ($modules as $module) {
            $quantity = (float) ($module['quantity'] ?? 1);
            $reference = trim($module['reference'] ?? '');
            $originalNumber = (int) ($module['number'] ?? 0);

            if ($quantity <= 1 || $reference === '') {
                if ($originalNumber > 0 && in_array($originalNumber, $usedNumbers, true)) {
                    continue;
                }

                $expanded[] = $module;

                if ($originalNumber > 0) {
                    $usedNumbers[] = $originalNumber;
                }

                continue;
            }

            $candidateNumbers = $despieceByReference->get($reference, []);

            $candidateNumbers = collect($candidateNumbers)
                ->filter(function ($number) use ($usedNumbers, $originalNumber) {
                    return !in_array((int) $number, $usedNumbers, true) && (int) $number >= $originalNumber;
                })
                ->values()
                ->all();

            if (count($candidateNumbers) < (int) $quantity) {
                if ($originalNumber > 0 && in_array($originalNumber, $usedNumbers, true)) {
                    continue;
                }

                $expanded[] = $module;

                if ($originalNumber > 0) {
                    $usedNumbers[] = $originalNumber;
                }

                continue;
            }

            $numbersToUse = array_slice($candidateNumbers, 0, (int) $quantity);

            $originalTotal = (float) ($module['total'] ?? $module['pvp'] ?? 0);
            $unitTotal = $quantity > 0 ? ($originalTotal / $quantity) : $originalTotal;

            foreach ($numbersToUse as $number) {
                $copy = $module;
                $copy['number'] = (int) $number;
                $copy['quantity'] = 1;
                $copy['total'] = $unitTotal;
                $copy['pvp'] = $unitTotal;
                $copy['grouped_quantity'] = $quantity;
                $copy['grouped_from_number'] = $originalNumber;
                $copy['expanded_from_grouped_module'] = true;

                $expanded[] = $copy;
                $usedNumbers[] = (int) $number;
            }
        }

        $expanded = collect($expanded)
            ->unique(function ($module) {
                return (int) ($module['number'] ?? 0);
            })
            ->values()
            ->all();

        usort($expanded, fn($a, $b) => ((int) ($a['number'] ?? 0)) <=> ((int) ($b['number'] ?? 0)));

        return $expanded;
    }
    private function syncModuleReferencesFromDespiece(array $modules, array $despiece): array
    {
        $referencesByNumber = collect($despiece)
            ->groupBy(function ($row) {
                return (int) ($row['module_number'] ?? 0);
            })
            ->map(function ($rows) {
                return $rows
                    ->pluck('module_reference')
                    ->map(fn($reference) => trim((string) $reference))
                    ->filter()
                    ->unique()
                    ->values();
            });

        foreach ($modules as $index => $module) {
            $number = (int) ($module['number'] ?? 0);

            if ($number <= 0) {
                continue;
            }

            $txtReferences = $referencesByNumber->get($number);

            if (!$txtReferences || $txtReferences->count() !== 1) {
                continue;
            }

            $txtReference = $txtReferences->first();
            $currentReference = trim((string) ($module['reference'] ?? ''));

            if ($txtReference !== '' && $txtReference !== $currentReference) {
                $modules[$index]['xml_reference'] = $currentReference;
                $modules[$index]['reference'] = $txtReference;
                $modules[$index]['reference_source'] = 'txt';
            }
        }

        return $modules;
    }
private function assignKitchenDrawStandardsToModules(array $modules): array
    {
        foreach ($modules as $index => $module) {
            $standard = $this->findClosestKitchenDrawModule($module);

            if (!$standard) {
                $modules[$index]['kd_match_status'] = 'unmatched';
                $modules[$index]['kd_standard_reference'] = null;
                $modules[$index]['kd_standard_dx'] = null;
                $modules[$index]['kd_standard_dy'] = null;
                $modules[$index]['kd_standard_dz'] = null;
                continue;
            }

            $modules[$index]['kd_match_status'] = (
                (float) ($module['dx'] ?? 0) == (float) $standard->dx &&
                (float) ($module['dy'] ?? 0) == (float) $standard->dy &&
                (float) ($module['dz'] ?? 0) == (float) $standard->dz
            ) ? 'exact' : 'adjusted';

            $modules[$index]['kd_standard_reference'] = $standard->reference;
            $modules[$index]['kd_standard_dx'] = (float) $standard->dx;
            $modules[$index]['kd_standard_dy'] = (float) $standard->dy;
            $modules[$index]['kd_standard_dz'] = (float) $standard->dz;
        }

        return $modules;
    }
    private function findClosestKitchenDrawModule(array $module): ?\App\Models\ModulePrice
    {
        $reference = trim((string) ($module['reference'] ?? ''));
        $familyPrefix = $this->getKitchenDrawReferenceFamily($reference);
        $dx = (float) ($module['dx'] ?? 0);
        $dy = (float) ($module['dy'] ?? 0);
        $dz = (float) ($module['dz'] ?? 0);

        if (
            $familyPrefix === '' ||
            $dx <= 0 ||
            $dy <= 0 ||
            $dz <= 0
        ) {
            return null;
        }

        $companyId = auth()->check()
            ? auth()->user()->company_id
            : 1;

        $exactMatch = \App\Models\ModulePrice::query()
            ->where('company_id', $companyId)
            ->where('source', 'kitchendraw_master')
            ->where('reference', 'like', $reference . '%')
            ->where('dx', $dx)
            ->where('dy', $dy)
            ->where('dz', $dz)
            ->first();

        if ($exactMatch) {
            return $exactMatch;
        }

        return \App\Models\ModulePrice::query()
            ->where('company_id', $companyId)
            ->where('source', 'kitchendraw_master')
            ->where('reference', 'like', $familyPrefix . '%')
            ->where('dx', '>=', $dx)
            ->where('dy', '>=', $dy)
            ->where('dz', '>=', $dz)
            ->orderByRaw('(dx - ?) + (dy - ?) + (dz - ?) asc', [$dx, $dy, $dz])
            ->orderBy('dx')
            ->orderBy('dy')
            ->orderBy('dz')
            ->first();
    }
    private function getKitchenDrawReferenceFamily(string $reference): string
    {
        $reference = trim($reference);

        if ($reference === '') {
            return '';
        }

        $reference = preg_replace('/\s+/', ' ', $reference);

        if (preg_match('/^(.*?)-\s*\d+(?:_\d+)*$/', $reference, $matches)) {
            return rtrim(trim($matches[1]), '- ');
        }

        if (preg_match('/^(.*?)-\s*\d+$/', $reference, $matches)) {
            return rtrim(trim($matches[1]), '- ');
        }

        return rtrim(trim($reference), '- ');
    }
