    public function jsonPreview(\Illuminate\Http\Request $request)
    {
        $request->validate([
            'json_file' => 'required|file',
        ]);

        $file = $request->file('json_file');

        if (strtolower($file->getClientOriginalExtension()) !== 'json') {
            return back()->withErrors(['json_file' => 'El archivo debe tener extension .json']);
        }

        $raw = file_get_contents($file->getRealPath());
        $payload = json_decode($raw, true);

        if (!is_array($payload)) {
            return back()->withErrors(['json_file' => 'No se pudo leer el JSON o el formato no es valido.']);
        }

        $parsedData = $this->normalizeEdificarImportJson($payload, $file->getClientOriginalName());

        $parsedData['modules'] = $this->assignKitchenDrawStandardsToModules($parsedData['modules']);

        $this->syncMaterialPricesFromDespiece($parsedData['despiece']);

        $validation = $this->validateParsedProject($parsedData, false);

        session([
            'edificar_preview_data' => [
                'header' => $parsedData['header'],
                'headings' => $parsedData['headings'],
                'modules' => $parsedData['modules'],
                'despiece' => $parsedData['despiece'],
                'files' => $parsedData['files'],
            ]
        ]);

        return view('projects.preview', [
            'header' => $parsedData['header'],
            'headings' => $parsedData['headings'],
            'modules' => $parsedData['modules'],
            'despiece' => $parsedData['despiece'],
            'files' => $parsedData['files'],
            'validation' => $validation,
        ]);
    }

    private function normalizeEdificarImportJson(array $payload, string $fileName): array
    {
        $header = $payload['header'] ?? [];
        $modulesRaw = $payload['modules'] ?? [];
        $partsRaw = $payload['parts'] ?? [];

        $modules = [];

        foreach ($modulesRaw as $module) {
            $modules[] = [
                'environment' => $module['environment'] ?? 'JSON',
                'number' => (int) ($module['number'] ?? 0),
                'item_id' => (string) ($module['item_id'] ?? ''),
                'catalog_file' => (string) ($module['catalog_file'] ?? ''),
                'catalog_code' => (string) ($module['catalog_code'] ?? ''),
                'catalog_name' => (string) ($module['catalog_name'] ?? ''),
                'reference' => trim((string) ($module['reference'] ?? '')),
                'description' => trim((string) ($module['description'] ?? '')),
                'alternate_code' => trim((string) ($module['alternate_code'] ?? '')),
                'manufacturing_note' => trim((string) ($module['manufacturing_note'] ?? '')),
                'quantity' => (float) ($module['quantity'] ?? 1),
                'pvp' => (float) ($module['pvp'] ?? 0),
                'total' => (float) ($module['total'] ?? 0),
                'dx' => (float) ($module['dx'] ?? 0),
                'dy' => (float) ($module['dy'] ?? 0),
                'dz' => (float) ($module['dz'] ?? 0),
                'catalog' => (string) ($module['catalog'] ?? ''),
                'model' => (string) ($module['model'] ?? ''),
                'color' => (string) ($module['color'] ?? ''),
            ];
        }

        $despiece = [];

        foreach ($partsRaw as $index => $part) {
            $materialRaw = trim((string) ($part['material_raw'] ?? ''));
            $material = trim((string) ($part['material'] ?? ''));

            if ($material === '' && $materialRaw !== '') {
                $materialInfo = $this->splitMaterialAndColor($materialRaw);
            } else {
                $materialInfo = [
                    'material' => $material,
                    'color_code' => trim((string) ($part['color_code'] ?? '')),
                    'color_description' => trim((string) ($part['color_description'] ?? '')),
                ];
            }

            $row = [
                'line_number' => (int) ($part['line_number'] ?? ($index + 1)),
                'type_code' => (int) ($part['type_code'] ?? 0),
                'type_name' => $this->partTypeName((int) ($part['type_code'] ?? 0)),
                'part' => trim((string) ($part['part'] ?? '')),
                'quantity' => (float) ($part['quantity'] ?? 0),
                'length' => (float) ($part['length'] ?? 0),
                'width' => (float) ($part['width'] ?? 0),
                'thickness' => (float) ($part['thickness'] ?? 0),
                'material_code' => trim((string) ($part['material_code'] ?? '')),
                'material' => $materialInfo['material'],
                'color_code' => $materialInfo['color_code'],
                'color_description' => $materialInfo['color_description'],
                'module_number' => (int) ($part['module_number'] ?? 0),
                'module_reference' => trim((string) ($part['module_reference'] ?? '')),
            ];

            $row = $this->applyMaterialCostToDespieceRow($row);

            $despiece[] = $row;
        }

        return [
            'header' => [
                'estimate_id' => (string) ($header['estimate_id'] ?? ''),
                'project_name' => (string) ($header['project_name'] ?? 'Proyecto JSON EDIFICAR'),
                'company_name' => (string) ($header['company_name'] ?? ''),
                'client_name' => (string) ($header['client_name'] ?? ''),
                'designer' => (string) ($header['designer'] ?? ''),
                'seller_name' => (string) ($header['seller_name'] ?? ''),
                'city' => (string) ($header['city'] ?? ''),
                'country' => (string) ($header['country'] ?? ''),
                'currency' => (string) ($header['currency'] ?? 'USD'),
                'state' => (string) ($header['state'] ?? ''),
                'creation_date' => (string) ($header['creation_date'] ?? ''),
                'update_date' => (string) ($header['update_date'] ?? ''),
                'total_without_tax' => (float) ($header['total_without_tax'] ?? 0),
                'total_with_tax' => (float) ($header['total_with_tax'] ?? 0),
            ],
            'headings' => [],
            'modules' => $modules,
            'despiece' => $despiece,
            'files' => [
                'xml' => null,
                'txt' => $fileName,
                'scn' => null,
                'json' => $fileName,
            ],
        ];
    }

    private function applyMaterialCostToDespieceRow(array $row): array
    {
        $materialPrice = \App\Models\MaterialPrice::query()
            ->where('material_code', $row['material_code'])
            ->where('is_active', true)
            ->first();

        $unitType = $materialPrice->unit_type ?? 'm2';
        $unitCost = (float) ($materialPrice->unit_cost ?? 0);
        $wastePercent = (float) ($materialPrice->waste_percent ?? 0);

        $quantity = (float) ($row['quantity'] ?? 0);
        $lengthMm = (float) ($row['length'] ?? 0);
        $widthMm = (float) ($row['width'] ?? 0);

        $consumption = 0;
        $areaM2 = 0;
        $linearM = 0;

        if ($unitType === 'm2') {
            $areaM2 = ($lengthMm / 1000) * ($widthMm / 1000) * $quantity;
            $consumption = $areaM2;
        } elseif ($unitType === 'ml') {
            $linearM = ($lengthMm / 1000) * $quantity;
            $consumption = $linearM;
        } else {
            $consumption = $quantity;
        }

        $baseCost = $consumption * $unitCost;
        $wasteCost = $baseCost * ($wastePercent / 100);
        $totalCost = $baseCost + $wasteCost;

        $row['unit_type'] = $unitType;
        $row['consumption'] = round($consumption, 4);
        $row['area_m2'] = round($areaM2, 4);
        $row['linear_m'] = round($linearM, 4);
        $row['unit_cost'] = round($unitCost, 4);
        $row['base_cost'] = round($baseCost, 4);
        $row['waste_percent'] = round($wastePercent, 2);
        $row['waste_cost'] = round($wasteCost, 4);
        $row['total_cost'] = round($totalCost, 4);

        return $row;
    }
    public function exportEdificarJson(\Illuminate\Http\Request $request)
    {
        $data = session('edificar_preview_data');

        if (!is_array($data)) {
            return back()->withErrors(['data' => 'No existe preview activo para exportar JSON.']);
        }

        $payload = $this->buildEdificarImportJson($data);

        $projectName = preg_replace('/[^A-Za-z0-9_\-]/', '_', $payload['header']['project_name'] ?? 'edificar_import');
        $fileName = 'edificar_import_' . $projectName . '_' . date('Ymd_His') . '.json';

        return response(json_encode($payload, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE))
            ->header('Content-Type', 'application/json; charset=UTF-8')
            ->header('Content-Disposition', 'attachment; filename="' . $fileName . '"');
    }

