    public function index(Request $request)
    {
        $user = auth()->user();

        $query = Project::query()->with(['company', 'user']);

        if (!$user->hasRole('superadmin')) {
            $query->where('company_id', $user->company_id);
        }

        if ($request->filled('search')) {
            $search = trim($request->search);

            $query->where(function ($q) use ($search) {
                $q->where('name', 'like', "%{$search}%")
                  ->orWhere('scn_data', 'like', "%{$search}%");
            });
        }

        if ($request->filled('status')) {
            $query->where('status', $request->status);
        }

        if ($user->hasRole('superadmin') && $request->filled('company')) {
            $query->where('company_id', $request->company);
        }

        $projects = $query
            ->latest()
            ->paginate(10)
            ->withQueryString();

        foreach ($projects as $project) {

            $data = json_decode($project->scn_data, true);

            $project->project_name = $data['header']['project_name'] ?? $project->name;
            $project->client_name = $data['header']['client_name'] ?? '-';
            $project->designer = $data['header']['designer'] ?? '-';
        }

        $totalProjects = Project::when(
            !$user->hasRole('superadmin'),
            fn ($q) => $q->where('company_id', $user->company_id)
        )->count();

        $validatedProjects = Project::when(
            !$user->hasRole('superadmin'),
            fn ($q) => $q->where('company_id', $user->company_id)
        )->where('status', 'technical_validated')->count();

        $observedProjects = Project::when(
            !$user->hasRole('superadmin'),
            fn ($q) => $q->where('company_id', $user->company_id)
        )->where('status', 'technical_observed')->count();

        $companies = \App\Models\Company::orderBy('name')->get();

        return view('projects.index', compact(
            'projects',
            'companies',
            'totalProjects',
            'validatedProjects',
            'observedProjects'
        ));
    }

