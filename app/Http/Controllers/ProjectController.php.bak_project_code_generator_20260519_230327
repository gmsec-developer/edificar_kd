    private function parseClipboardTable(string $raw): array
    {
        $raw = str_replace(["\r\n", "\r"], "\n", trim($raw));

        $handle = fopen('php://temp', 'r+');
        fwrite($handle, $raw);
        rewind($handle);

        $rows = [];

        while (($row = fgetcsv($handle, 0, "\t")) !== false) {
            if (count(array_filter($row, fn($v) => trim((string) $v) !== '')) === 0) {
                continue;
            }

            $rows[] = array_map(fn($v) => trim((string) $v), $row);
        }

        fclose($handle);

        return $rows;
    }

    private function parseClipboardDecimal(string $value): float
    {
        $value = trim($value);
        $value = str_replace('.', '', $value);
        $value = str_replace(',', '.', $value);

        return (float) $value;
    }

    private function parseClipboardModules(string $raw): array
    {
        $rows = $this->parseClipboardTable($raw);
        $modules = [];

        foreach ($rows as $row) {
            if (count($row) < 8) {
                continue;
            }

            $modules[] = [
                'number' => (int) ($row[0] ?? 0),
                'reference' => trim($row[1] ?? ''),
                'description' => trim(preg_replace('/\s+/', ' ', $row[3] ?? '')),
                'quantity' => (float) ($row[4] ?? 0),
                'unit_price' => $this->parseClipboardDecimal($row[6] ?? '0'),
                'total_price' => $this->parseClipboardDecimal($row[7] ?? '0'),
            ];
        }

        return $modules;
    }

    private function parseClipboardParts(string $raw): array
    {
        $rows = $this->parseClipboardTable($raw);
        $parts = [];

        foreach ($rows as $row) {
            if (count($row) < 11) {
                continue;
            }

            $materialInfo = $this->splitMaterialAndColor($row[9] ?? '');

            $parts[] = [
                'module_number' => (int) ($row[0] ?? 0),
                'module_reference' => trim($row[1] ?? ''),
                'module_name' => trim($row[2] ?? ''),
                'type_code' => (int) ($row[3] ?? 0),
                'type_name' => $this->partTypeName((int) ($row[3] ?? 0)),
                'part' => trim($row[4] ?? ''),
                'quantity' => (float) ($row[5] ?? 0),
                'length' => (float) ($row[6] ?? 0),
                'width' => (float) ($row[7] ?? 0),
                'side' => trim($row[8] ?? ''),
                'material_raw' => trim($row[9] ?? ''),
                'material' => $materialInfo['material'],
                'color_code' => $materialInfo['color_code'],
                'color_description' => $materialInfo['color_description'],
                'thickness' => (float) ($row[10] ?? 0),
            ];
        }

        return $parts;
    }
