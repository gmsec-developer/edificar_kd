    private function validateFileExtensions(Request $request): void
    {
        $rules = [
            'xml_file' => 'xml',
            'txt_file' => 'txt',
            'scn_file' => 'scn',
        ];

        foreach ($rules as $field => $extension) {
            $file = $request->file($field);

            if (!$file) {
                continue;
            }

            if (strtolower($file->getClientOriginalExtension()) !== $extension) {
                $labels = [
                    'xml_file' => 'XML',
                    'txt_file' => 'TXT',
                    'scn_file' => 'SCN',
                ];

                $label = $labels[$field] ?? $field;

                throw \Illuminate\Validation\ValidationException::withMessages([
                    $field => 'El archivo ' . $label . ' debe tener extension .' . $extension . '.',
                ]);
            }
        }
    }

    private function validateParsedProject(array $data, bool $checkDuplicates = false): array
    {
        $critical = [];
        $warnings = [];

        $header = $data['header'] ?? [];
        $modules = $data['modules'] ?? [];
        $despiece = $data['despiece'] ?? [];

        if (empty($header['project_name'])) {
            $critical[] = 'No se encontro nombre de proyecto.';
        }

        if (empty($header['client_name'])) {
            $critical[] = 'No se encontro nombre de cliente.';
        }

        if (count($modules) === 0) {
            $critical[] = 'No se encontraron modulos en el XML.';
        }

        if (count($despiece) === 0) {
            $critical[] = 'No se encontro despiece en el TXT.';
        }

        $rawModuleNumbers = collect($modules)
            ->pluck('number')
            ->map(fn($n) => (int) $n);

        $duplicateModules = $rawModuleNumbers
            ->duplicates()
            ->unique()
            ->values();

        if ($duplicateModules->count() > 0) {
            $critical[] = 'Hay numeros de modulo duplicados en XML: ' . $duplicateModules->implode(', ');
        }

        $moduleNumbers = $rawModuleNumbers->unique()->values();

        $despieceNumbers = collect($despiece)
            ->pluck('module_number')
            ->map(fn($n) => (int) $n)
            ->unique();

        $modulesWithoutParts = $moduleNumbers->diff($despieceNumbers)->values();
        $partsWithoutModule = $despieceNumbers->diff($moduleNumbers)->values();

        if ($modulesWithoutParts->count() > 0) {
            $critical[] = 'Hay modulos sin despiece: ' . $modulesWithoutParts->implode(', ');
        }

        if ($partsWithoutModule->count() > 0) {
            $critical[] = 'Hay despiece que no coincide con modulos XML: ' . $partsWithoutModule->implode(', ');
        }

        $xmlReferencesByNumber = collect($modules)
            ->groupBy(fn($module) => (int) ($module['number'] ?? 0))
            ->map(function ($items) {
                return trim((string) ($items->first()['reference'] ?? ''));
            });

        $txtReferencesByNumber = collect($despiece)
            ->groupBy(fn($row) => (int) ($row['module_number'] ?? 0))
            ->map(function ($items) {
                return $items
                    ->pluck('module_reference')
                    ->map(fn($reference) => trim((string) $reference))
                    ->filter()
                    ->unique()
                    ->values();
            });

        foreach ($xmlReferencesByNumber as $moduleNumber => $xmlReference) {
            if ((int) $moduleNumber <= 0 || $xmlReference === '') {
                continue;
            }

            $txtReferences = $txtReferencesByNumber->get((int) $moduleNumber);

            if (!$txtReferences || $txtReferences->count() === 0) {
                continue;
            }

            if (!$txtReferences->contains($xmlReference)) {
                $critical[] = 'Modulo ' . $moduleNumber . ' no coincide entre XML y TXT. XML: ' . $xmlReference . ' | TXT: ' . $txtReferences->implode(', ');
            }

            if ($txtReferences->count() > 1) {
                $critical[] = 'Modulo ' . $moduleNumber . ' tiene referencias mezcladas en TXT: ' . $txtReferences->implode(', ');
            }
        }

        foreach ($modules as $module) {

            $moduleNumber = (int) ($module['number'] ?? 0);

            $dx = (float) ($module['dx'] ?? 0);
            $dy = (float) ($module['dy'] ?? 0);
            $dz = (float) ($module['dz'] ?? 0);

            if ($dx <= 0 || $dy <= 0 || $dz <= 0) {
                $critical[] = 'Modulo ' . $moduleNumber . ' tiene medidas invalidas.';
            }
        }

        foreach ($despiece as $index => $row) {
            $line = $index + 1;

            if (empty($row['part'])) {
                $critical[] = 'Linea despiece ' . $line . ': pieza vacia.';
            }

            if (empty($row['material_code']) || empty($row['material'])) {
                $warnings[] = 'Linea despiece ' . $line . ': material incompleto.';
            }

            if (empty($row['quantity']) || empty($row['length']) || empty($row['width'])) {
                $critical[] = 'Linea despiece ' . $line . ': medidas principales incompletas.';
            }

            if (
                (float) ($row['quantity'] ?? 0) <= 0 ||
                (float) ($row['length'] ?? 0) <= 0 ||
                (float) ($row['width'] ?? 0) <= 0
            ) {
                $critical[] = 'Linea despiece ' . $line . ': medidas invalidas o menores a cero.';
            }

            if (empty($row['thickness'])) {
                $warnings[] = 'Linea despiece ' . $line . ': espesor no definido.';
            }

            if (($row['type_code'] == 1 || $row['type_code'] == 2) && empty($row['color_code'])) {
                $warnings[] = 'Linea despiece ' . $line . ': color no separado.';
            }
        }

        if ($checkDuplicates && $this->sceneAlreadyExists($data)) {
            $critical[] = 'Esta escena parece ya importada anteriormente.';
        }

        return [
            'critical' => $critical,
            'warnings' => $warnings,
            'critical_count' => count($critical),
            'warning_count' => count($warnings),
        ];
    }

    private function sceneAlreadyExists(array $data): bool
    {
        $header = $data['header'] ?? [];
        $files = $data['files'] ?? [];

        $estimateId = trim($header['estimate_id'] ?? '');
        $projectName = trim($header['project_name'] ?? '');
        $clientName = trim($header['client_name'] ?? '');
        $xmlName = trim($files['xml'] ?? '');
        $txtName = trim($files['txt'] ?? '');

        $projects = Project::where('company_id', auth()->user()->company_id)->get();

        foreach ($projects as $project) {
            $saved = json_decode($project->scn_data, true);

            if (!$saved) {
                continue;
            }

            $savedHeader = $saved['header'] ?? [];
            $savedFiles = $saved['files'] ?? [];

            if ($estimateId !== '' && $estimateId === trim($savedHeader['estimate_id'] ?? '')) {
                return true;
            }

            if ($xmlName !== '' && $txtName !== '' && $xmlName === trim($savedFiles['xml'] ?? '') && $txtName === trim($savedFiles['txt'] ?? '')) {
                return true;
            }

            if ($projectName !== '' && $clientName !== ''
                && $projectName === trim($savedHeader['project_name'] ?? '')
                && $clientName === trim($savedHeader['client_name'] ?? '')) {
                return true;
            }
        }

        return false;
    }

    private function parseKitchenDrawXml($file): array
    {
        $content = file_get_contents($file->getRealPath());

        libxml_use_internal_errors(true);
        $xml = simplexml_load_string($content);
        libxml_clear_errors();

        if (!$xml) {
            throw \Illuminate\Validation\ValidationException::withMessages([
                'xml_file' => 'No se pudo leer el archivo XML. Verifique que el archivo sea valido.',
            ]);
        }

        $header = [
            'estimate_id' => (string) ($xml->EstimateId ?? ''),
            'project_name' => (string) ($xml->CustomerCompany ?? $xml['Name'] ?? ''),
            'company_name' => (string) ($xml->CustomerBusiness ?? ''),
            'client_name' => trim((string) ($xml->CustomerFirstName ?? '') . ' ' . (string) ($xml->CustomerName ?? '')),
            'designer' => (string) ($xml->SellerId ?? ''),
            'seller_name' => (string) ($xml->SellerName ?? ''),
            'city' => (string) ($xml->CustomerCity ?? ''),
            'country' => (string) ($xml->CustomerCountry ?? ''),
            'currency' => (string) (($xml->Currency[0]['Code'] ?? 'USD')),
            'state' => (string) ($xml->State ?? ''),
            'creation_date' => (string) ($xml->CreationDate ?? ''),
            'update_date' => (string) ($xml->UpdateDate ?? ''),
            'total_without_tax' => $this->getXmlSellPrice($xml, 'Net', '0'),
            'total_with_tax' => $this->getXmlSellPrice($xml, 'Net', '1'),
        ];

        $headings = [];
        $modules = [];

        foreach ($xml->Headings->Heading ?? [] as $heading) {
            $headingName = (string) ($heading['Name'] ?? 'Sin ambiente');

            $headingData = [
                'name' => $headingName,
                'catalog' => (string) ($heading->CatalogName ?? ''),
                'model' => (string) ($heading->Model['Name'] ?? ''),
                'total_without_tax' => $this->getXmlSellPrice($heading, 'Net', '0'),
                'total_with_tax' => $this->getXmlSellPrice($heading, 'Net', '1'),
                'items_count' => 0,
            ];

            foreach ($heading->Items->Item ?? [] as $item) {
                $number = (int) ($item->Number ?? 0);

                $modules[] = [
                    'environment' => $headingName,
                    'number' => $number,
                    'item_id' => (string) ($item->ItemId ?? ''),
                    'catalog_file' => (string) ($heading->CatalogFileName ?? ''),
                    'catalog_code' => (string) ($heading->CatalogCode ?? ''),
                    'catalog_name' => (string) ($heading->CatalogName ?? ''),
                    'reference' => (string) ($item['Reference'] ?? ''),
                    'description' => trim((string) ($item->Description ?? '')),
                    'alternate_code' => trim((string) ($item->UserRef ?? '')),
                    'manufacturing_note' => trim((string) ($item->ModifiedDescription ?? '')),
                    'quantity' => (float) ($item->Quantity ?? 0),
                    'pvp' => $this->getXmlSellPrice($item, 'Net', '1'),
                    'total' => $this->getXmlSellPrice($item, 'NetTotal', '1'),
                    'dx' => (string) ($item->Dx ?? ''),
                    'dy' => (string) ($item->Dy ?? ''),
                    'dz' => (string) ($item->Dz ?? ''),
                    'catalog' => (string) ($item->CatalogName ?? ''),
                    'model' => (string) ($item->Model['Name'] ?? ''),
                    'color' => (string) ($item->Detail->Name ?? ''),
                ];

                $headingData['items_count']++;
            }

            $headings[] = $headingData;
        }

        usort($modules, fn($a, $b) => $a['number'] <=> $b['number']);

        return [
            'header' => $header,
            'headings' => $headings,
            'modules' => $modules,
        ];
    }

    private function parseKitchenDrawTxt($file): array
    {
        $rows = [];
        $handle = fopen($file->getRealPath(), 'r');

        if (!$handle) {
            throw \Illuminate\Validation\ValidationException::withMessages([
                'txt_file' => 'No se pudo leer el archivo TXT de despiece.',
            ]);
        }

        while (($data = fgetcsv($handle, 0, ',')) !== false) {
            if (count($data) < 10) {
                continue;
            }

            $materialRaw = trim($data[7], '" ');
            $materialInfo = $this->splitMaterialAndColor($materialRaw);

            $rows[] = [
                'type_code' => (int) $data[0],
                'type_name' => $this->partTypeName((int) $data[0]),
                'part' => trim($data[1], '" '),
                'quantity' => (float) $data[2],
                'length' => (float) $data[3],
                'width' => (float) $data[4],
                'thickness' => (float) $data[5],
                'material_code' => trim($data[6], '" '),
                'material' => $materialInfo['material'],
                'color_code' => $materialInfo['color_code'],
                'color_description' => $materialInfo['color_description'],
                'module_number' => (int) $data[8],
                'module_reference' => trim($data[9], '" '),
            ];
        }

        fclose($handle);

        return $rows;
    }

    private function splitMaterialAndColor(string $materialRaw): array
    {
        $materialRaw = trim($materialRaw);

        if (str_contains($materialRaw, '_')) {
            [$material, $colorRaw] = explode('_', $materialRaw, 2);

            $colorRaw = trim($colorRaw);

            if (str_contains($colorRaw, ' ')) {
                [$colorCode, $colorDescription] = explode(' ', $colorRaw, 2);
            } else {
                $colorCode = $colorRaw;
                $colorDescription = '';
            }

            return [
                'material' => trim($material),
                'color_code' => trim($colorCode),
                'color_description' => trim($colorDescription),
            ];
        }

        return [
            'material' => $materialRaw,
            'color_code' => '',
            'color_description' => '',
        ];
    }

    private function expandModulesFromDespiece(array $modules, array $despiece): array
    {
        $expanded = [];
        $usedNumbers = [];

        $despieceByReference = collect($despiece)
            ->filter(function ($row) {
                return isset($row['module_number']) && (int) $row['module_number'] > 0;
            })
            ->groupBy(function ($row) {
                return trim($row['module_reference'] ?? '');
            })
            ->map(function ($rows) {
                return $rows
                    ->pluck('module_number')
                    ->map(fn($number) => (int) $number)
                    ->unique()
                    ->sort()
                    ->values()
                    ->all();
            });

        foreach ($modules as $module) {
            $quantity = (float) ($module['quantity'] ?? 1);
            $reference = trim($module['reference'] ?? '');
            $originalNumber = (int) ($module['number'] ?? 0);

            if ($quantity <= 1 || $reference === '') {
                $expanded[] = $module;
                $usedNumbers[] = $originalNumber;
                continue;
            }

            $candidateNumbers = $despieceByReference->get($reference, []);

            $candidateNumbers = collect($candidateNumbers)
                ->filter(function ($number) use ($usedNumbers, $originalNumber) {
                    return !in_array((int) $number, $usedNumbers, true) && (int) $number >= $originalNumber;
                })
                ->values()
                ->all();

            if (count($candidateNumbers) < (int) $quantity) {
                $expanded[] = $module;
                $usedNumbers[] = $originalNumber;
                continue;
            }

            $numbersToUse = array_slice($candidateNumbers, 0, (int) $quantity);

            foreach ($numbersToUse as $number) {
                $copy = $module;
                $copy['number'] = (int) $number;
                $copy['quantity'] = 1;
                $copy['total'] = $module['pvp'] ?? $module['total'] ?? 0;
                $copy['grouped_quantity'] = $quantity;
                $copy['grouped_from_number'] = $originalNumber;

                $expanded[] = $copy;
                $usedNumbers[] = (int) $number;
            }
        }

        usort($expanded, fn($a, $b) => ((int) ($a['number'] ?? 0)) <=> ((int) ($b['number'] ?? 0)));

        return $expanded;
    }


    private function findClosestKitchenDrawModule(array $module): ?\App\Models\ModulePrice
    {
        $catalogCode = trim((string) ($module['catalog_code'] ?? ''));
        $typeCode = trim((string) ($module['model'] ?? ''));
        $reference = trim((string) ($module['reference'] ?? ''));
        $familyPrefix = $this->getKitchenDrawReferenceFamily($reference);
        $dx = (float) ($module['dx'] ?? 0);
        $dy = (float) ($module['dy'] ?? 0);
        $dz = (float) ($module['dz'] ?? 0);

        if (
            $catalogCode === '' ||
            $typeCode === '' ||
            $familyPrefix === '' ||
            $dx <= 0 ||
            $dy <= 0 ||
            $dz <= 0
        ) {
            return null;
        }

        $companyId = auth()->check()
            ? auth()->user()->company_id
            : 1;

        return \App\Models\ModulePrice::query()
            ->where('company_id', $companyId)
            ->where('source', 'kitchendraw_master')
            ->where('catalog_code', $catalogCode)
            ->where('type_code', $typeCode)
            ->where('reference', 'like', $familyPrefix . '-%')
            ->where('dx', '>=', $dx)
            ->where('dy', '>=', $dy)
            ->where('dz', '>=', $dz)
            ->orderByRaw('(dx - ?) + (dy - ?) + (dz - ?) asc', [$dx, $dy, $dz])
            ->orderBy('dx')
            ->orderBy('dy')
            ->orderBy('dz')
            ->first();
    }
    private function getKitchenDrawReferenceFamily(string $reference): string
    {
        $reference = trim($reference);

        if ($reference === '') {
            return '';
        }

        $reference = preg_replace('/\s+/', ' ', $reference);

        if (preg_match('/^(.*?)-\s*\d+(?:_\d+)*$/', $reference, $matches)) {
            return rtrim(trim($matches[1]), '- ');
        }

        return rtrim(trim($reference), '- ');
    }
    private function syncModulePricesFromModules(array $modules): void
    {
        $companyId = auth()->user()->company_id;

        foreach ($modules as $module) {
            $catalogCode = trim($module['catalog_code'] ?? '');
            $catalogName = trim($module['catalog_name'] ?? '');
            $reference = trim($module['reference'] ?? '');

            $dx = (float) ($module['dx'] ?? 0);
            $dy = (float) ($module['dy'] ?? 0);
            $dz = (float) ($module['dz'] ?? 0);

            if ($catalogCode === '' || $reference === '') {
                continue;
            }

            ModulePrice::firstOrCreate(
                [
                    'company_id' => $companyId,
                    'catalog_code' => $catalogCode,
                    'reference' => $reference,
                    'dx' => $dx,
                    'dy' => $dy,
                    'dz' => $dz,
                ],
                [
                    'catalog_name' => $catalogName,
                    'description_base' => trim($module['description'] ?? ''),
                    'model' => trim($module['model'] ?? ''),
                    'complexity_level' => 'simple',
                    'complexity_factor' => 1.00,
                    'labor_cost' => 0,
                    'indirect_cost' => 0,
                    'default_waste_percent' => 10,
                    'is_active' => true,
                ]
            );
        }
    }


    private function syncMaterialPricesFromDespiece(array $despiece): void
    {
        $companyId = auth()->user()->company_id;

        foreach ($despiece as $row) {
            $materialCode = trim($row['material_code'] ?? '');
            $materialName = trim($row['material'] ?? '');
            $colorCode = trim($row['color_code'] ?? '');
            $colorName = trim($row['color_description'] ?? '');

            if ($materialCode === '' || $materialName === '') {
                continue;
            }

            MaterialPrice::firstOrCreate(
                [
                    'company_id' => $companyId,
                    'material_code' => $materialCode,
                    'color_code' => $colorCode,
                ],
                [
                    'material_name' => $materialName,
                    'color_name' => $colorName,
                    'unit_type' => 'm2',
                    'unit_cost' => 0,
                    'is_active' => true,
                ]
            );
        }
    }

    private function getXmlSellPrice($node, string $type, string $withTax): ?string
    {
        foreach ($node->SellPrice ?? [] as $price) {
            if ((string) ($price['Type'] ?? '') === $type && (string) ($price['WithTax'] ?? '') === $withTax) {
                return (string) $price;
            }
        }

        return null;
    }

    private function partTypeName(int $type): string
    {
        return match ($type) {
            1 => 'Pieza',
            2 => 'Puerta/Frente',
            4 => 'Accesorio/Material',
            default => 'Tipo ' . $type,
        };
    }
